<Window x:Class="TecnologApp.Views.RecipeComponentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Компоненты рецептуры" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Text="Компоненты рецептуры" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Форма добавления компонента -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cmbMaterial" Width="200" Height="35" 
                          DisplayMemberPath="name" SelectedValuePath="id"
                          Margin="0,0,10,0"/>
                <TextBox x:Name="txtPercentage" Width="100" Height="35" 
                         ToolTip="Процент содержания" Margin="0,0,10,0"/>
                <TextBlock Text="%" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtLoadOrder" Width="80" Height="35" 
                         ToolTip="Порядок загрузки" Margin="0,0,10,0"/>
                <Button x:Name="btnAddComponent" Content="+ Добавить" 
                        Width="100" Height="35" Background="#2196F3" 
                        Foreground="White" Click="BtnAddComponent_Click"/>
            </StackPanel>
        </Border>

        <!-- Таблица компонентов -->
        <DataGrid x:Name="dgComponents" Grid.Row="2" 
                  AutoGenerateColumns="False" Height="250"
                  IsReadOnly="True" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="50" Binding="{Binding id}"/>
                <DataGridTextColumn Header="Материал" Width="200" Binding="{Binding material_name}"/>
                <DataGridTextColumn Header="%" Width="80" Binding="{Binding percentage}"/>
                <DataGridTextColumn Header="Порядок" Width="80" Binding="{Binding load_order}"/>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑️" Width="30" 
                                    Click="BtnDeleteComponent_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Информация о сумме -->
        <Border Grid.Row="3" Background="#FFF3E0" CornerRadius="10" Padding="15" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Сумма компонентов: " FontWeight="Bold"/>
                <TextBlock x:Name="txtTotalPercentage" Text="0%" FontWeight="Bold"/>
                <TextBlock x:Name="txtStatus" Text="" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>