<Page x:Class="TecnologApp.Views.BatchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BatchesPage"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Производственные партии" 
                   FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Фильтры и кнопки -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbStatusFilter" Width="150" Height="30"
                          SelectionChanged="CmbStatusFilter_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="planned"/>
                    <ComboBoxItem Content="running"/>
                    <ComboBoxItem Content="paused"/>
                    <ComboBoxItem Content="completed"/>
                    <ComboBoxItem Content="blocked"/>
                </ComboBox>
                <Button x:Name="btnRefresh" Content="🔄 Обновить" 
                        Width="100" Height="35" Margin="20,0,0,0"
                        Click="BtnRefresh_Click"/>
                <CheckBox x:Name="chkOnlyWithDeviations" 
                          Content="Только с отклонениями" 
                          VerticalAlignment="Center" Margin="20,0,0,0"
                          Checked="ChkFilter_Changed" Unchecked="ChkFilter_Changed"/>
            </StackPanel>
        </Border>

        <!-- Таблица партий -->
        <DataGrid x:Name="dgBatches" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single"
                  RowHeaderWidth="0"
                  Height="450"
                  AlternatingRowBackground="#F9F9F9"
                  MouseDoubleClick="DgBatches_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="50" Binding="{Binding id}"/>
                <DataGridTextColumn Header="Номер партии" Width="120" Binding="{Binding batch_number}"/>
                <DataGridTextColumn Header="Продукт" Width="200" Binding="{Binding product_name}"/>
                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding status}"/>
                <DataGridTextColumn Header="Заказ" Width="120" Binding="{Binding order_number}"/>
                <DataGridTextColumn Header="Дата запуска" Width="150" Binding="{Binding start_time}"/>
                <DataGridTextColumn Header="Кол-во (кг)" Width="100" Binding="{Binding actual_quantity_kg}"/>
                <DataGridTextColumn Header="Отклонения" Width="100" Binding="{Binding deviation_count}"/>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📋" Width="35" Margin="2" 
                                    Click="BtnDetails_Click" Tag="{Binding}"
                                    ToolTip="Детали партии"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="txtInfo" Grid.Row="3" 
                   Foreground="Gray" Margin="0,10,0,0" FontSize="12"/>
    </Grid>
</Page>