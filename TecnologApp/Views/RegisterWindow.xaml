<Window x:Class="TecnologApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TecnologApp.Views"
        mc:Ignorable="d"
         Title="Регистрация пользователя" 
        Height="550" Width="450" 
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Регистрация нового пользователя" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Логин" Margin="0,0,0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="2" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Пароль" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Text="ФИО" Margin="0,0,0,5"/>
        <TextBox x:Name="txtFullName" Grid.Row="6" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="7" Text="Email" Margin="0,0,0,5"/>
        <TextBox x:Name="txtEmail" Grid.Row="8" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="9" Text="Телефон" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPhone" Grid.Row="10" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="11" Text="Отдел" Margin="0,0,0,5"/>
        <TextBox x:Name="txtDepartment" Grid.Row="12" Height="35" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                    Width="180" Height="40" Background="#2E7D32" 
                    Foreground="White" Click="BtnRegister_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" 
                    Width="100" Height="40" Margin="10,0,0,0"
                    Click="BtnCancel_Click"/>
        </StackPanel>

        <TextBlock x:Name="txtError" Grid.Row="14" Foreground="Red" 
                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>
