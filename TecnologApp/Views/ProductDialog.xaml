<Window x:Class="TecnologApp.Views.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Продукт" Height="400" Width="450"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавление/Редактирование продукта" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Код продукта" Margin="0,0,0,5"/>
        <TextBox x:Name="txtCode" Grid.Row="2" Height="35" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Наименование" Margin="0,0,0,5"/>
        <TextBox x:Name="txtName" Grid.Row="4" Height="35" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="5" Text="Тип" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbType" Grid.Row="6" Height="35" Margin="0,0,0,15">
            <ComboBoxItem Content="herbicide"/>
            <ComboBoxItem Content="insecticide"/>
            <ComboBoxItem Content="fungicide"/>
            <ComboBoxItem Content="other"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Text="Форма выпуска" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbForm" Grid.Row="8" Height="35" Margin="0,0,0,20">
            <ComboBoxItem Content="liquid"/>
            <ComboBoxItem Content="powder"/>
            <ComboBoxItem Content="granules"/>
        </ComboBox>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35"
                    Background="#4CAF50" Foreground="White" Click="BtnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" 
                    Margin="10,0,0,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>