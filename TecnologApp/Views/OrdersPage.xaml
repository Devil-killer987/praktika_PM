<Page x:Class="TecnologApp.Views.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="OrdersPage"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Производственные заказы" 
                   FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Фильтры и кнопки -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbStatusFilter" Width="150" Height="30"
                          SelectionChanged="CmbStatusFilter_SelectionChanged">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="planned"/>
                    <ComboBoxItem Content="in_progress"/>
                    <ComboBoxItem Content="completed"/>
                    <ComboBoxItem Content="cancelled"/>
                </ComboBox>
                <Button x:Name="btnAdd" Content="+ Создать заказ" 
                        Width="150" Height="35" Margin="20,0,0,0"
                        Background="#4CAF50" Foreground="White" Click="BtnAdd_Click"/>
                <Button x:Name="btnRefresh" Content="🔄 Обновить" 
                        Width="100" Height="35" Margin="10,0,0,0"
                        Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- Таблица заказов -->
        <DataGrid x:Name="dgOrders" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single"
                  RowHeaderWidth="0"
                  Height="400"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="50" Binding="{Binding id}"/>
                <DataGridTextColumn Header="Номер заказа" Width="120" Binding="{Binding order_number}"/>
                <DataGridTextColumn Header="Продукт" Width="200" Binding="{Binding product_name}"/>
                <DataGridTextColumn Header="Количество (кг)" Width="120" Binding="{Binding planned_quantity_kg}"/>
                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding status}"/>
                <DataGridTextColumn Header="Дата запуска" Width="120" Binding="{Binding planned_start_date}"/>
                <DataGridTemplateColumn Header="Действия" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▶️" Width="35" Margin="2" 
                                        Click="BtnStart_Click" Tag="{Binding}"
                                        ToolTip="Запустить заказ"/>
                                <Button Content="📋" Width="35" Margin="2" 
                                        Click="BtnDetails_Click" Tag="{Binding}"
                                        ToolTip="Детали"/>
                                <Button Content="✏️" Width="35" Margin="2" 
                                        Click="BtnEdit_Click" Tag="{Binding}"
                                        ToolTip="Редактировать"/>
                                <Button Content="🗑️" Width="35" Margin="2" 
                                        Click="BtnDelete_Click" Tag="{Binding}"
                                        ToolTip="Удалить"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="txtInfo" Grid.Row="3" 
                   Foreground="Gray" Margin="0,10,0,0" FontSize="12"/>
    </Grid>
</Page>