<Window x:Class="TecnologApp.Views.TechCardStepsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шаги технологической карты" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Text="Шаги технологической карты" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Форма добавления шага -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название шага" Margin="0,0,5,5"/>
                <TextBox x:Name="txtStepName" Grid.Row="1" Grid.Column="0" Height="35" Margin="0,0,10,10"/>

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Температура (°C)" Margin="0,0,5,5"/>
                <TextBox x:Name="txtTemp" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,0,10,10"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Длительность (мин)" Margin="0,0,5,5"/>
                <TextBox x:Name="txtDuration" Grid.Row="1" Grid.Column="2" Height="35" Margin="0,0,10,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Давление (бар)" Margin="0,0,5,5"/>
                <TextBox x:Name="txtPressure" Grid.Row="3" Grid.Column="0" Height="35" Margin="0,0,10,0"/>

                <TextBlock Grid.Row="2" Grid.Column="1" Text="Допуск по температуре" Margin="0,0,5,5"/>
                <TextBox x:Name="txtTempTolerance" Grid.Row="3" Grid.Column="1" Height="35" Margin="0,0,10,0"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Обязательный" Margin="0,0,5,5"/>
                <CheckBox x:Name="chkMandatory" Grid.Row="3" Grid.Column="2" 
                          VerticalAlignment="Center" Margin="0,0,10,0"/>

                <Button x:Name="btnAddStep" Grid.Row="3" Grid.Column="3" 
                        Content="+ Добавить шаг" Width="120" Height="35"
                        Background="#2196F3" Foreground="White" 
                        Click="BtnAddStep_Click" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- Таблица шагов -->
        <DataGrid x:Name="dgSteps" Grid.Row="2" 
                  AutoGenerateColumns="False" Height="300"
                  IsReadOnly="True" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Порядок" Width="60" Binding="{Binding step_order}"/>
                <DataGridTextColumn Header="Название" Width="180" Binding="{Binding step_name}"/>
                <DataGridTextColumn Header="Температура" Width="100" Binding="{Binding planned_temp_c}"/>
                <DataGridTextColumn Header="Длительность" Width="100" Binding="{Binding planned_duration_min}"/>
                <DataGridTextColumn Header="Давление" Width="100" Binding="{Binding planned_pressure_bar}"/>
                <DataGridTextColumn Header="Обязательный" Width="100" Binding="{Binding is_mandatory}"/>
                <DataGridTemplateColumn Header="Действия" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑️" Width="30" 
                                    Click="BtnDeleteStep_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>