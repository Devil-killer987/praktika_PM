<Window x:Class="TecnologApp.Views.BatchDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали партии" Height="500" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Text="Детали партии" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Информация о партии -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер партии:" FontWeight="Bold"/>
                <TextBlock x:Name="txtBatchNumber" Grid.Row="0" Grid.Column="1"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Продукт:" FontWeight="Bold"/>
                <TextBlock x:Name="txtProduct" Grid.Row="0" Grid.Column="3"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" FontWeight="Bold"/>
                <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Отклонения:" FontWeight="Bold"/>
                <TextBlock x:Name="txtDeviations" Grid.Row="1" Grid.Column="3"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата запуска:" FontWeight="Bold"/>
                <TextBlock x:Name="txtStartTime" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Дата завершения:" FontWeight="Bold"/>
                <TextBlock x:Name="txtEndTime" Grid.Row="2" Grid.Column="3"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="План (кг):" FontWeight="Bold"/>
                <TextBlock x:Name="txtPlannedQty" Grid.Row="3" Grid.Column="1"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="Факт (кг):" FontWeight="Bold"/>
                <TextBlock x:Name="txtActualQty" Grid.Row="3" Grid.Column="3"/>
            </Grid>
        </Border>

        <!-- Таблица шагов -->
        <TextBlock Grid.Row="2" Text="Шаги выполнения" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgSteps" Grid.Row="3" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Width="50" Binding="{Binding step_order}"/>
                <DataGridTextColumn Header="Шаг" Width="150" Binding="{Binding step_name}"/>
                <DataGridTextColumn Header="Температура" Width="100" Binding="{Binding actual_temp_c}"/>
                <DataGridTextColumn Header="Длительность" Width="100" Binding="{Binding actual_duration_min}"/>
                <DataGridTextColumn Header="Давление" Width="100" Binding="{Binding actual_pressure_bar}"/>
                <DataGridTextColumn Header="Отклонение" Width="100" Binding="{Binding deviation_flag}"/>
                <DataGridTextColumn Header="Комментарий" Width="200" Binding="{Binding operator_comment}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>