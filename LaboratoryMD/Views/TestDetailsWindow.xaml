<Window x:Class="LaboratoryMD.Views.TestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали испытания" Height="487" Width="594"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Детали лабораторного испытания" 
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Информация об испытании -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" FontWeight="Bold"/>
                <TextBlock x:Name="txtSampleType" Grid.Row="0" Grid.Column="1"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Объект:" FontWeight="Bold"/>
                <TextBlock x:Name="txtObjectName" Grid.Row="0" Grid.Column="3"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" FontWeight="Bold"/>
                <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="1"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Решение:" FontWeight="Bold"/>
                <TextBlock x:Name="txtDecision" Grid.Row="1" Grid.Column="3"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата анализа:" FontWeight="Bold"/>
                <TextBlock x:Name="txtAnalysisDate" Grid.Row="2" Grid.Column="1"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Комментарий:" FontWeight="Bold" VerticalAlignment="Top"/>
                <TextBlock x:Name="txtComment" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" 
                           TextWrapping="Wrap" Margin="0,5,0,0"/>
            </Grid>
        </Border>

        <!-- Таблица результатов -->
        <TextBlock Grid.Row="2" Text="Результаты анализа" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgResults" Grid.Row="3" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9" Margin="0,0,0,26">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Параметр" Width="150" Binding="{Binding parameter_name}"/>
                <DataGridTextColumn Header="Норма" Width="120" Binding="{Binding standard_value}"/>
                <DataGridTextColumn Header="Ед.изм" Width="80" Binding="{Binding unit}"/>
                <DataGridTextColumn Header="Факт" Width="100" Binding="{Binding measured_value}"/>
                <DataGridTextColumn Header="Результат" Width="80" Binding="{Binding result}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35"
                    Click="BtnClose_Click" Margin="0,197,0,-13"/>
        </StackPanel>
    </Grid>
</Window>