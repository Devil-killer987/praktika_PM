<Window x:Class="LaboratoryMD.Views.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторное испытание" Height="637" Width="659"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="txtTitle" Text="Испытание" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Информация об объекте контроля -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="txtObjectInfo" Text="" FontWeight="Bold" FontSize="14"/>
                <TextBlock x:Name="txtDetails" Text="" FontSize="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Таблица параметров -->
        <DataGrid x:Name="dgParameters" Grid.Row="2" 
                  AutoGenerateColumns="False" 
                  Height="250"
                  AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Параметр" Width="150" Binding="{Binding parameter_name}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Норма" Width="120" Binding="{Binding standard_value}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ед.изм" Width="80" Binding="{Binding unit}" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Фактическое значение" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding measured_value, UpdateSourceTrigger=PropertyChanged}"
                                     Width="130" Height="25" VerticalContentAlignment="Center"
                                     LostFocus="TextBox_LostFocus" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Статус" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock x:Name="txtStatus" Text="{Binding result}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Комментарий и решение -->
        <Border Grid.Row="3" Background="#FFF3E0" CornerRadius="10" 
                Padding="15" Margin="0,15,0,0">
            <StackPanel>
                <TextBlock Text="Комментарий лаборанта" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtComment" Height="60" TextWrapping="Wrap" 
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Text="Итоговое решение:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbDecision" Width="150" Height="30" IsEnabled="False">
                        <ComboBoxItem Content="Одобрить" IsSelected="True"/>
                        <ComboBoxItem Content="Забраковать"/>
                    </ComboBox>
                    <Button x:Name="btnSave" Content="💾 Сохранить протокол" 
                            Width="150" Height="35" Margin="20,0,0,0"
                            Background="#4CAF50" Foreground="White" Click="BtnSave_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>