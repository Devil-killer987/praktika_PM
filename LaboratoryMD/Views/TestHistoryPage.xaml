<Page x:Class="LaboratoryMD.Views.TestHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TestHistoryPage"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="История лабораторных испытаний" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <DataGrid x:Name="dgHistory" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9"
                  MouseDoubleClick="DgHistory_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="50" Binding="{Binding id}"/>
                <DataGridTextColumn Header="Тип" Width="120" Binding="{Binding sample_type}"/>
                <DataGridTextColumn Header="Объект" Width="200" Binding="{Binding object_name}"/>
                <DataGridTextColumn Header="Дата анализа" Width="150" Binding="{Binding analysis_date}"/>
                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding status}"/>
                <DataGridTextColumn Header="Решение" Width="100" Binding="{Binding decision}"/>
                <DataGridTemplateColumn Header="Действие" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="📋" Width="30" Click="BtnView_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>