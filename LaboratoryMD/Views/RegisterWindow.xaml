<Window x:Class="LaboratoryMD.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="607" Width="450"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Регистрация пользователя" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Логин *" Margin="0,0,0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="2" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Text="Пароль*" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Text="ФИО*" Margin="0,0,0,5"/>
        <TextBox x:Name="txtFullName" Grid.Row="6" Height="35" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="7" Text="Email*" Margin="0,0,0,5"/>
        <TextBox x:Name="txtEmail" Grid.Row="7" Height="35" Margin="56,0,10,216"/>

        <TextBlock Grid.Row="7" Text="Телефон*" Margin="0,45,0,0"/>
        <TextBox x:Name="txtPhone" Grid.Row="7" Height="35" Margin="56,40,10,176"/>

        <TextBlock Grid.Row="7" Text="Отдел*" Margin="0,85,0,0"/>
        <TextBox x:Name="txtDepartment" Grid.Row="7" Height="35" Margin="56,80,10,136"/>

        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                    Width="180" Height="35" Background="#2E7D32" 
                    Foreground="White" Click="BtnRegister_Click" Margin="0,152,0,64"/>
            <Button x:Name="btnCancel" Content="Отмена" 
                    Width="100" Height="35" Margin="10,152,0,64"
                    Click="BtnCancel_Click"/>
        </StackPanel>

        <TextBlock x:Name="txtError" Grid.Row="14" Foreground="Red" 
                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,190,0,0"/>
    </Grid>
</Window>