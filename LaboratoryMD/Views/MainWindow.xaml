<Window x:Class="LaboratoryMD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Лаборатория" 
        Height="700" Width="1100" 
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Background="#1A252F" Padding="10">
                    <TextBlock Text="АгроКонтроль" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                </Border>

                <Border Background="#34495E" Padding="10" Margin="0,10,0,10">
                    <StackPanel>
                        <TextBlock x:Name="txtUserName" Text="Лаборант" 
                                   Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="txtUserRole" Text="Лаборатория ОТК" 
                                   Foreground="#BDC3C7" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Button x:Name="btnRawMaterials" Content="📦 Сырье на контроле" 
                        FontSize="14" Height="45" HorizontalAlignment="Stretch"
                        Cursor="Hand" Click="BtnRawMaterials_Click"
                        Background="Transparent" Foreground="White" BorderThickness="0"/>

                <Button x:Name="btnFinishedProducts" Content="🏭 Готовая продукция" 
                        FontSize="14" Height="45" HorizontalAlignment="Stretch"
                        Cursor="Hand" Click="BtnFinishedProducts_Click"
                        Background="Transparent" Foreground="White" BorderThickness="0"/>

                <Button x:Name="btnHistory" Content="📋 История испытаний" 
                        FontSize="14" Height="45" HorizontalAlignment="Stretch"
                        Cursor="Hand" Click="BtnHistory_Click"
                        Background="Transparent" Foreground="White" BorderThickness="0"/>

                <Border Height="1" Background="#34495E" Margin="10,20,10,10"/>

                <Button x:Name="btnLogout" Content="🚪 Выход" 
                        FontSize="14" Height="45" HorizontalAlignment="Stretch"
                        Cursor="Hand" Click="BtnLogout_Click"
                        Background="Transparent" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>