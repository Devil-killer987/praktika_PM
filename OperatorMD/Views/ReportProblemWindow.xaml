<Window x:Class="OperatorMD.Views.ReportProblemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сообщить о проблеме" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⚠ Сообщение о проблеме" 
                   FontSize="20" FontWeight="Bold" Foreground="Red" 
                   Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Выберите партию" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbBatch" Grid.Row="2" Height="35" 
                  DisplayMemberPath="batch_number" SelectedValuePath="id"
                  Margin="0,0,0,15"/>

        <TextBlock Grid.Row="3" Text="Тип проблемы" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbProblemType" Grid.Row="4" Height="35" Margin="0,0,0,15">
            <ComboBoxItem Content="Технологическое отклонение" IsSelected="True"/>
            <ComboBoxItem Content="Неисправность оборудования"/>
            <ComboBoxItem Content="Проблема с сырьем"/>
            <ComboBoxItem Content="Безопасность"/>
            <ComboBoxItem Content="Другое"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Text="Описание проблемы" Margin="0,0,0,5"/>
        <TextBox x:Name="txtDescription" Grid.Row="6" Height="120" 
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSend" Content="Отправить" Width="100" Height="35"
                    Background="#F44336" Foreground="White" Click="BtnSend_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" 
                    Margin="10,0,0,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>