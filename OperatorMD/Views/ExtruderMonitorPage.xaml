<Page x:Class="OperatorMD.Views.ExtruderMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ExtruderMonitorPage"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Экструдер - Мониторинг в реальном времени" 
                   FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Информация о линии -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" 
                Padding="15" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Линия" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="txtLine" Text="Линия №1" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Текущая партия" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="txtCurrentBatch" Text="—" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель с параметрами -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Карточка температуры -->
            <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,15,15">
                <StackPanel>
                    <TextBlock Text="🌡 ТЕМПЕРАТУРА" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="txtTemperature" Text="0" FontSize="48" FontWeight="Bold"/>
                    <TextBlock Text="°C" FontSize="16" Margin="0,-10,0,0"/>
                    <ProgressBar x:Name="tempProgress" Height="10" Margin="0,15,0,0" 
                                 Minimum="0" Maximum="150" Value="0"/>
                    <TextBlock x:Name="txtTempStatus" Text="Норма" FontSize="12" 
                               Foreground="Violet" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Карточка давления -->
            <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,15,15">
                <StackPanel>
                    <TextBlock Text="⏲ ДАВЛЕНИЕ" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="txtPressure" Text="0" FontSize="48" FontWeight="Bold"/>
                    <TextBlock Text="бар" FontSize="16" Margin="0,-10,0,0"/>
                    <ProgressBar x:Name="pressureProgress" Height="10" Margin="0,15,0,0" 
                                 Minimum="0" Maximum="10" Value="0"/>
                    <TextBlock x:Name="txtPressureStatus" Text="Норма" FontSize="12" 
                               Foreground="Violet" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Карточка оборотов -->
            <Border Grid.Row="0" Grid.Column="2" Background="White" CornerRadius="10" 
                    Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="🌀 ОБОРОТЫ" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="txtRPM" Text="0" FontSize="48" FontWeight="Bold"/>
                    <TextBlock Text="об/мин" FontSize="16" Margin="0,-10,0,0"/>
                    <ProgressBar x:Name="rpmProgress" Height="10" Margin="0,15,0,0" 
                                 Minimum="0" Maximum="3000" Value="0"/>
                    <TextBlock x:Name="txtRPMStatus" Text="Норма" FontSize="12" 
                               Foreground="Violet" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Статус оборудования -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                    Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="🔧 СОСТОЯНИЕ ОБОРУДОВАНИЯ" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="txtEquipmentStatus" Text="Работает" 
                               FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtLastUpdate" Text="Последнее обновление: —" 
                               FontSize="11" Foreground="Gray" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>