<Window x:Class="OperatorMD.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АгроКонтроль - Аппаратчик" 
        Height="500" Width="450" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ООО АгроКонтроль" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Модуль аппаратчика" 
                   FontSize="14" Foreground="Gray" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <TextBlock Grid.Row="2" Text="Смена / Линия" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
            <ComboBox x:Name="cmbShift" Width="120" Height="35" Margin="0,0,10,0">
                <ComboBoxItem Content="Смена А" IsSelected="True"/>
                <ComboBoxItem Content="Смена Б"/>
                <ComboBoxItem Content="Смена В"/>
            </ComboBox>
            <ComboBox x:Name="cmbLine" Width="120" Height="35">
                <ComboBoxItem Content="Линия №1" IsSelected="True"/>
                <ComboBoxItem Content="Линия №2"/>
                <ComboBoxItem Content="Линия №3"/>
            </ComboBox>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Логин" Margin="0,0,0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="5" 
                 Height="35" Margin="0,0,0,15" FontSize="14"/>

        <TextBlock Grid.Row="6" Text="Пароль" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="7" 
                     Height="35" Margin="0,3,0,129" FontSize="14"/>

        <Button x:Name="btnLogin" Grid.Row="7" Content="Войти" 
                Width="120" Height="40" 
                Background="Chocolate" Foreground="White"
                FontSize="14" HorizontalAlignment="Center"
                Click="BtnLogin_Click" Margin="142,79,142,48"/>

        <TextBlock x:Name="txtError" Grid.Row="9" 
                   Foreground="Red" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>