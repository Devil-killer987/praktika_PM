<Page x:Class="OperatorMD.Views.ActiveBatchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ActiveBatchesPage"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Активные партии" 
                   FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#FFF3E0" CornerRadius="10" 
                Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Информация" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Выберите партию для выполнения операций. 
Активные партии - это партии со статусом &quot;running&quot; или &quot;paused&quot;." 
                           TextWrapping="Wrap" FontSize="12"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="itemsBatches" Margin="0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" 
                                Width="320" Height="180" Margin="0,0,15,15"
                                Padding="15" BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                MouseLeftButtonUp="BatchCard_Click"
                                Tag="{Binding}">
                            <StackPanel>
                                <Border CornerRadius="5" Padding="5,2" 
                                        Background="#34495E" Width="80" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding status}" 
                                               Foreground="White" FontSize="10"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="{Binding batch_number}" 
                                           FontSize="16" FontWeight="Bold" 
                                           Margin="0,10,0,5"/>

                                <TextBlock Text="{Binding product_name}" 
                                           FontSize="14" Foreground="#555"/>

                                <TextBlock Text="Текущий шаг:" 
                                           FontSize="11" Foreground="Gray" 
                                           Margin="0,10,0,2"/>
                                <TextBlock Text="{Binding current_step}" 
                                           FontSize="13" FontWeight="Bold"/>

                                <TextBlock Text="Прогресс:" 
                                           FontSize="11" Foreground="Gray" 
                                           Margin="0,8,0,2"/>
                                <ProgressBar Value="{Binding current_step_progress}" 
                                             Maximum="{Binding total_steps}" 
                                             Height="8" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding current_step_progress, StringFormat={}{0}/{1} шагов}" 
                                           FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>